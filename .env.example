# =============================================================================
# Staffing Match Dashboard — Environment Variables
# Copy to .env and fill in values.
# =============================================================================

# ---------------------------------------------------------------------------
# Portal authentication (required)
# ---------------------------------------------------------------------------
PORTAL_USERNAME=admin
PORTAL_PASSWORD=admin   # change this in production

# ---------------------------------------------------------------------------
# Azure Cosmos DB (required)
# ---------------------------------------------------------------------------
USE_COSMOS=true
COSMOS_ENDPOINT=https://localhost:8081
COSMOS_KEY=
COSMOS_DATABASE=staffing_agent
COSMOS_CONTAINER=bench_roster
REPORT_CACHE_BLOB_CONTAINER=report-cache

# ---------------------------------------------------------------------------
# Azure OpenAI (required for AI-Analyze feature on dashboard)
# ---------------------------------------------------------------------------
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-14
AZURE_CHAT_DEPLOYMENT=gpt-4.1
AZURE_EMBED_DEPLOYMENT=text-embedding-3-large

# ---------------------------------------------------------------------------
# Skill embedding (optional)
# ---------------------------------------------------------------------------
SKILL_EMBED_ENABLED=false
SKILL_EMBED_SIMILARITY_THRESHOLD=0.90
SKILL_EQUIV_LLM_REVALIDATE=true
